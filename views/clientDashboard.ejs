<div class="row">
    <div class="col-12">
        <!-- ===== Header ===== -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap" style="gap: 15px;">
            <div>
                <h2 style="color: #0a1628; font-weight: 800; margin: 0; font-size: 2rem;">
                    <i class="bi bi-speedometer2" style="color: #c9a84c;"></i> My Dashboard
                </h2>
                <p style="color: rgba(10, 22, 40, 0.5); margin: 0; font-size: 1.05rem;">
                    <i class="bi bi-person-circle" style="color: #c9a84c;"></i> Welcome back, <strong style="color: #0a1628; font-size: 1.1rem;"><%= typeof user !== 'undefined' ? user.name : 'Guest' %></strong>!
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.7rem; padding: 5px 15px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                        <i class="bi bi-person"></i> Client
                    </span>
                </p>
            </div>
            <a href="/client/appointment/new" class="btn" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; padding: 12px 30px; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.85rem;">
                <i class="bi bi-plus-circle"></i> New Appointment
            </a>
        </div>
        
        <!-- ===== Stats Cards ===== -->
        <div class="row mb-4 g-3">
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border-radius: 16px; padding: 22px 25px; color: white; box-shadow: 0 4px 20px rgba(10, 22, 40, 0.12); transition: all 0.3s ease; border: 1px solid rgba(201, 168, 76, 0.08);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1" style="color: rgba(232, 213, 163, 0.5); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; font-size: 0.85rem;">
                                <i class="bi bi-calendar-check" style="color: #c9a84c;"></i> Total
                            </h6>
                            <h2 class="mb-0" style="font-weight: 900; color: #c9a84c; font-size: 3rem;"><%= typeof appointments !== 'undefined' ? appointments.length : 0 %></h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.15; color: #c9a84c;">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, #e65100, #bf360c); border-radius: 16px; padding: 22px 25px; color: white; box-shadow: 0 4px 20px rgba(230, 81, 0, 0.15); transition: all 0.3s ease;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1" style="color: rgba(255, 255, 255, 0.6); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; font-size: 0.85rem;">
                                <i class="bi bi-clock-history"></i> Pending
                            </h6>
                            <h2 class="mb-0" style="font-weight: 900; font-size: 3rem;"><%= typeof appointments !== 'undefined' ? appointments.filter(a => a.status === 'pending').length : 0 %></h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.15;">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, #2e7d32, #1b5e20); border-radius: 16px; padding: 22px 25px; color: white; box-shadow: 0 4px 20px rgba(46, 125, 50, 0.15); transition: all 0.3s ease;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1" style="color: rgba(255, 255, 255, 0.6); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; font-size: 0.85rem;">
                                <i class="bi bi-check-circle"></i> Completed
                            </h6>
                            <h2 class="mb-0" style="font-weight: 900; font-size: 3rem;"><%= typeof appointments !== 'undefined' ? appointments.filter(a => a.status === 'completed').length : 0 %></h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.15;">
                            <i class="bi bi-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== SEARCH BAR ===== -->
        <div class="row mb-3 g-2">
            <div class="col-md-6 col-lg-5">
                <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 15px rgba(10, 22, 40, 0.04);">
                    <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 20px;">
                        <i class="bi bi-search" style="font-size: 1.2rem;"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by PO Number or Docket Number..." style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 20px; border-radius: 0 12px 12px 0; transition: all 0.3s ease; font-size: 1rem;">
                </div>
            </div>
            <div class="col-md-6 col-lg-7 text-md-end mt-2 mt-md-0">
                <span class="badge" style="background: rgba(201, 168, 76, 0.08); color: #0a1628; padding: 10px 20px; border-radius: 50px; font-size: 0.85rem; border: 1px solid rgba(201, 168, 76, 0.1);">
                    <i class="bi bi-info-circle" style="color: #c9a84c;"></i> 
                    <span id="searchCount"><%= typeof appointments !== 'undefined' ? appointments.length : 0 %></span> appointments found
                </span>
            </div>
        </div>

        <!-- ===== Appointments Table ===== -->
        <div class="card shadow" style="border-radius: 16px; border: 1px solid rgba(201, 168, 76, 0.08); overflow: hidden;">
            <div class="card-header" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border: none; padding: 20px 25px;">
                <h5 class="mb-0" style="color: #e8d5a3; font-weight: 700; font-size: 1.3rem;">
                    <i class="bi bi-list-ul" style="color: #c9a84c;"></i> My Appointments
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.7rem; padding: 5px 15px; border-radius: 20px; margin-left: 10px;">
                        <%= typeof appointments !== 'undefined' ? appointments.length : 0 %> Total
                    </span>
                </h5>
            </div>
            <div class="card-body" style="padding: 0;">
                <% if (typeof appointments !== 'undefined' && appointments.length === 0) { %>
                    <div class="text-center py-5" style="background: #f8f4eb;">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: rgba(201, 168, 76, 0.2);"></i>
                        <h5 style="color: #0a1628; margin-top: 15px; font-size: 1.3rem;">No Appointments Found</h5>
                        <p style="color: rgba(10, 22, 40, 0.4); font-size: 1rem;">Start by creating your first appointment</p>
                        <a href="/client/appointment/new" class="btn" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; padding: 12px 35px; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease; font-size: 0.85rem;">
                            <i class="bi bi-plus-circle"></i> Create First Appointment
                        </a>
                    </div>
                <% } else if (typeof appointments !== 'undefined' && appointments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table" style="margin: 0;" id="appointmentsTable">
                            <thead>
                                <tr>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-hash" style="color: #c9a84c; font-size: 1rem;"></i> ID
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-file-text" style="color: #c9a84c; font-size: 1rem;"></i> PO Number
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-receipt" style="color: #c9a84c; font-size: 1rem;"></i> Invoice
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-box-seam" style="color: #c9a84c; font-size: 1rem;"></i> Docket
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-calendar3" style="color: #c9a84c; font-size: 1rem;"></i> Delivery
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; text-align: center; white-space: nowrap;">
                                        <i class="bi bi-tag" style="color: #c9a84c; font-size: 1rem;"></i> Status
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; text-align: center; white-space: nowrap;">
                                        <i class="bi bi-eye" style="color: #c9a84c; font-size: 1rem;"></i> Action
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% appointments.forEach((app, index) => { %>
                                    <tr style="border-bottom: 1px solid rgba(10, 22, 40, 0.06); transition: all 0.3s ease;" data-po="<%= app.poNumber.toLowerCase() %>" data-docket="<%= (app.docketNumber || '').toLowerCase() %>">
                                        <td style="padding: 14px 18px; vertical-align: middle;">
                                            <strong style="color: #0a1628; font-size: 0.95rem;"><%= app.appointmentId %></strong>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.95rem;">
                                            <%= app.poNumber %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.95rem;">
                                            <%= app.invoiceNumber %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.95rem;">
                                            <%= app.docketNumber || '-' %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.95rem; white-space: nowrap;">
                                            <i class="bi bi-calendar" style="color: #c9a84c; font-size: 0.8rem;"></i>
                                            <%= new Date(app.deliveryDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; text-align: center;">
                                            <span class="badge" style="background: <%= app.status === 'pending' ? 'linear-gradient(135deg, #e65100, #bf360c)' : app.status === 'confirmed' ? 'linear-gradient(135deg, #00695c, #004d40)' : 'linear-gradient(135deg, #2e7d32, #1b5e20)' %>; color: white; padding: 6px 16px; border-radius: 50px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; white-space: nowrap;">
                                                <i class="bi bi-<%= app.status === 'pending' ? 'clock-history' : app.status === 'confirmed' ? 'check-circle' : 'check-circle-fill' %>"></i>
                                                <%= app.status %>
                                            </span>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; text-align: center;">
                                            <a href="/client/appointment/<%= app._id %>" class="btn btn-sm" style="background: rgba(201, 168, 76, 0.1); color: #c9a84c; border: 1px solid rgba(201, 168, 76, 0.15); border-radius: 6px; padding: 6px 14px; transition: all 0.3s ease; font-weight: 600; font-size: 0.7rem;">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5" style="background: #f8f4eb;">
                        <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: rgba(201, 168, 76, 0.2);"></i>
                        <h5 style="color: #0a1628; margin-top: 15px; font-size: 1.3rem;">Something went wrong!</h5>
                        <p style="color: rgba(10, 22, 40, 0.4); font-size: 1rem;">Please try again later.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- ===== SEARCH JAVASCRIPT ===== -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const rows = document.querySelectorAll('#appointmentsTable tbody tr');
    const searchCount = document.getElementById('searchCount');
    const totalCount = rows.length;

    searchInput.addEventListener('keyup', function() {
        const searchTerm = this.value.toLowerCase().trim();
        let visibleCount = 0;

        rows.forEach(row => {
            const poNumber = row.getAttribute('data-po') || '';
            const docketNumber = row.getAttribute('data-docket') || '';
            
            if (poNumber.includes(searchTerm) || docketNumber.includes(searchTerm)) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        if (searchTerm === '') {
            searchCount.textContent = totalCount;
        } else {
            searchCount.textContent = visibleCount;
        }
    });
});
</script>

<!-- ===== Extra Styles ===== -->
<style>
    /* Stat Card Hover Effect */
    .stat-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 40px rgba(10, 22, 40, 0.2) !important;
    }
    
    /* Table Row Hover */
    .table tbody tr:hover {
        background: rgba(201, 168, 76, 0.05) !important;
        transform: scale(1.01);
    }
    
    /* View Button Hover */
    .table tbody .btn-sm:hover {
        background: linear-gradient(135deg, #c9a84c, #a8873a) !important;
        color: #0a1628 !important;
        border-color: #c9a84c !important;
        transform: translateY(-2px) scale(1.05);
    }
    
    /* New Appointment Button Hover */
    .btn[href="/client/appointment/new"]:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 40px rgba(201, 168, 76, 0.45) !important;
        background: linear-gradient(135deg, #e8d5a3, #c9a84c) !important;
    }
    
    /* Create First Appointment Button Hover */
    .text-center .btn:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 40px rgba(201, 168, 76, 0.45) !important;
        background: linear-gradient(135deg, #e8d5a3, #c9a84c) !important;
    }
    
    /* Search Input Focus */
    #searchInput:focus {
        border-color: #c9a84c !important;
        box-shadow: none !important;
    }
    
    .input-group:focus-within {
        box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.12) !important;
        border-radius: 12px !important;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .d-flex.justify-content-between {
            flex-direction: column;
            align-items: stretch !important;
        }
        
        .d-flex.justify-content-between a {
            width: 100%;
            text-align: center;
        }
        
        .stat-card {
            padding: 15px 20px !important;
        }
        
        .stat-card h2 {
            font-size: 2rem !important;
        }
        
        .table thead th {
            font-size: 0.6rem !important;
            padding: 10px 12px !important;
        }
        
        .table tbody td {
            font-size: 0.8rem !important;
            padding: 10px 12px !important;
        }
    }
    
    @media (max-width: 576px) {
        .table thead th {
            font-size: 0.5rem !important;
            padding: 8px 10px !important;
        }
        
        .table tbody td {
            font-size: 0.7rem !important;
            padding: 8px 10px !important;
        }
        
        .badge {
            font-size: 0.55rem !important;
            padding: 4px 10px !important;
        }
        
        .btn-sm {
            font-size: 0.6rem !important;
            padding: 4px 10px !important;
        }
        
        .stat-card h2 {
            font-size: 1.8rem !important;
        }
        
        .stat-card {
            padding: 12px 15px !important;
        }
    }
</style>