<!-- Add this extra style for navbar link hover effects -->
<style>
    /* Navbar Link Hover Effects */
    .navbar-nav .nav-link {
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .navbar-nav .nav-link:not([href="/logout"]):not([href="/signup"]):hover {
        color: #c9a84c !important;
        transform: translateY(-2px);
    }
    
    .navbar-nav .nav-link:not([href="/logout"]):not([href="/signup"])::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #c9a84c, #e8d5a3);
        transition: all 0.3s ease;
        transform: translateX(-50%);
        border-radius: 2px;
    }
    
    .navbar-nav .nav-link:not([href="/logout"]):not([href="/signup"]):hover::after {
        width: 70%;
    }
    
    /* Logout Button Hover */
    .navbar-nav .nav-link[href="/logout"]:hover {
        background: rgba(201, 168, 76, 0.08) !important;
        border-color: rgba(201, 168, 76, 0.2) !important;
        color: #c9a84c !important;
        transform: translateY(-2px);
    }
    
    /* Signup Button Hover */
    .navbar-nav .nav-link[href="/signup"]:hover {
        transform: translateY(-3px) scale(1.04);
        box-shadow: 0 8px 40px rgba(201, 168, 76, 0.45) !important;
        background: linear-gradient(135deg, #e8d5a3, #c9a84c) !important;
    }
    
    /* Login Button Hover */
    .navbar-nav .nav-link[href="/login"]:hover {
        color: #e8d5a3 !important;
        transform: translateY(-2px);
    }
    
    /* Notification Bell Hover */
    .navbar-nav .nav-link .bi-bell {
        transition: all 0.3s ease;
    }
    
    .navbar-nav .nav-link:hover .bi-bell {
        transform: rotate(15deg) scale(1.1);
        color: #c9a84c !important;
    }
    
    /* User Profile Hover */
    .navbar-nav .d-flex.align-items-center.gap-3 {
        transition: all 0.3s ease;
    }
    
    .navbar-nav .d-flex.align-items-center.gap-3:hover {
        background: rgba(201, 168, 76, 0.1) !important;
        border-color: rgba(201, 168, 76, 0.2) !important;
        transform: translateY(-2px);
    }
    
    /* Mobile Responsive */
    @media (max-width: 992px) {
        .navbar {
            background: #0a1628 !important;
        }
        
        .navbar-nav .nav-link::after {
            display: none;
        }
        
        .navbar-nav .nav-link[href="/logout"] {
            background: rgba(201, 168, 76, 0.05);
            border: 1px solid rgba(201, 168, 76, 0.1);
            border-radius: 50px;
            text-align: center;
            justify-content: center;
        }
        
        .navbar-nav .nav-link[href="/signup"] {
            border-radius: 50px;
            text-align: center;
            justify-content: center;
        }
        
        .navbar-nav .d-flex.align-items-center.gap-3 {
            justify-content: center;
            width: 100%;
            margin-bottom: 10px;
        }
        
        .navbar-nav {
            gap: 10px !important;
            padding: 10px 0;
        }
        
        .navbar-nav .nav-item {
            width: 100%;
        }
        
        .navbar-nav .nav-link {
            justify-content: center;
            text-align: center;
        }
    }
    
    @media (max-width: 576px) {
        .navbar-brand {
            gap: 10px !important;
        }
        
        .navbar-brand img {
            height: 38px !important;
        }
        
        .navbar-brand span {
            font-size: 1rem !important;
        }
        
        .navbar-brand small {
            font-size: 0.4rem !important;
            letter-spacing: 2px !important;
        }
        
        .container-fluid {
            padding-left: 15px !important;
            padding-right: 15px !important;
        }
    }
</style>