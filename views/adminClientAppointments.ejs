<div class="row">
    <div class="col-12">
        <!-- ===== Header ===== -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap" style="gap: 15px;">
            <div>
                <h3 style="color: #0a1628; font-weight: 800; margin: 0; font-size: 1.8rem;">
                    <i class="bi bi-person" style="color: #c9a84c;"></i> 
                    <%= typeof client !== 'undefined' ? client.name : 'Client' %>'s Appointments
                </h3>
                <p style="color: rgba(10, 22, 40, 0.5); margin: 5px 0 0; font-size: 1rem;">
                    <i class="bi bi-envelope" style="color: #c9a84c;"></i> 
                    <%= typeof client !== 'undefined' ? client.email : '' %>
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.7rem; padding: 5px 15px; border-radius: 20px; margin-left: 10px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                        <i class="bi bi-calendar-check"></i> 
                        <%= typeof appointments !== 'undefined' ? appointments.length : 0 %> Total
                    </span>
                </p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/admin/dashboard" class="btn" style="background: rgba(10, 22, 40, 0.05); color: #0a1628; font-weight: 600; border: 2px solid rgba(10, 22, 40, 0.1); border-radius: 50px; padding: 12px 30px; transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.8rem;">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
                <a href="/admin/client/<%= typeof client !== 'undefined' ? client._id : '' %>" class="btn" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; padding: 12px 30px; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.8rem;">
                    <i class="bi bi-person"></i> Client Details
                </a>
            </div>
        </div>
        
        <!-- ===== FILTER + SEARCH ===== -->
        <div class="row mb-3 g-2">
            <div class="col-md-3">
                <select id="clientAppStatusFilter" class="form-select" style="border-radius: 12px; border: 2px solid #e8d5a3; padding: 12px 18px; font-weight: 600; background: white; color: #0a1628; cursor: pointer; transition: all 0.3s ease;" onchange="filterClientAppTable()">
                    <option value="all">📋 All Status</option>
                    <option value="pending">⏳ Pending</option>
                    <option value="confirmed">✅ Confirmed</option>
                    <option value="delivered">📦 Delivered</option>
                </select>
            </div>
            <div class="col-md-6 col-lg-5">
                <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 15px rgba(10, 22, 40, 0.04);">
                    <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 20px; font-size: 1.1rem;">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" id="clientAppSearchInput" class="form-control" placeholder="Search by PO, Docket, City, Invoice or ID..." style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 20px; border-radius: 0 12px 12px 0; transition: all 0.3s ease; font-size: 1rem;" onkeyup="filterClientAppTable()">
                </div>
            </div>
            <div class="col-md-3 text-md-end mt-2 mt-md-0">
                <span class="badge" style="background: rgba(201, 168, 76, 0.08); color: #0a1628; padding: 10px 20px; border-radius: 50px; font-size: 0.8rem; border: 1px solid rgba(201, 168, 76, 0.1);">
                    <i class="bi bi-info-circle" style="color: #c9a84c;"></i> 
                    <span id="clientAppSearchCount"><%= typeof appointments !== 'undefined' ? appointments.length : 0 %></span> appointments found
                </span>
            </div>
        </div>

        <!-- ===== Appointments Table ===== -->
        <div class="card shadow" style="border-radius: 16px; border: 1px solid rgba(201, 168, 76, 0.08); overflow: hidden;">
            <div class="card-header" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border: none; padding: 20px 25px;">
                <h5 class="mb-0" style="color: #e8d5a3; font-weight: 700; font-size: 1.3rem;">
                    <i class="bi bi-list-ul" style="color: #c9a84c;"></i> Appointment Details
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.7rem; padding: 5px 15px; border-radius: 20px; margin-left: 10px;">
                        <%= typeof appointments !== 'undefined' ? appointments.length : 0 %> Records
                    </span>
                </h5>
            </div>
            <div class="card-body" style="padding: 0;">
                <% if (typeof appointments !== 'undefined' && appointments.length === 0) { %>
                    <div class="text-center py-5" style="background: #f8f4eb;">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: rgba(201, 168, 76, 0.2);"></i>
                        <h5 style="color: #0a1628; margin-top: 15px; font-size: 1.3rem;">No Appointments Found</h5>
                        <p style="color: rgba(10, 22, 40, 0.4); font-size: 1rem;">This client hasn't created any appointments yet.</p>
                    </div>
                <% } else if (typeof appointments !== 'undefined' && appointments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table" style="margin: 0;" id="clientAppTable">
                            <thead>
                                <tr>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-hash" style="color: #c9a84c; font-size: 1rem;"></i> ID
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-file-text" style="color: #c9a84c; font-size: 1rem;"></i> PO
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-receipt" style="color: #c9a84c; font-size: 1rem;"></i> Invoice
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-building" style="color: #c9a84c; font-size: 1rem;"></i> City
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-box-seam" style="color: #c9a84c; font-size: 1rem;"></i> Docket
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-truck" style="color: #c9a84c; font-size: 1rem;"></i> Forwarder
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; white-space: nowrap;">
                                        <i class="bi bi-upc-scan" style="color: #c9a84c; font-size: 1rem;"></i> LR No.
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; text-align: center; white-space: nowrap;">
                                        <i class="bi bi-tag" style="color: #c9a84c; font-size: 1rem;"></i> Status
                                    </th>
                                    <th style="background: #f8f4eb; color: #0a1628; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; padding: 14px 18px; border-bottom: 3px solid #c9a84c; text-align: center; white-space: nowrap;">
                                        <i class="bi bi-gear" style="color: #c9a84c; font-size: 1rem;"></i> Actions
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% appointments.forEach((app, index) => { %>
                                    <tr style="border-bottom: 1px solid rgba(10, 22, 40, 0.06); transition: all 0.3s ease;" 
                                        data-po="<%= app.poNumber.toLowerCase() %>" 
                                        data-docket="<%= (app.docketNumber || '').toLowerCase() %>"
                                        data-invoice="<%= app.invoiceNumber.toLowerCase() %>"
                                        data-city="<%= (app.city || '').toLowerCase() %>"
                                        data-id="<%= app.appointmentId.toLowerCase() %>"
                                        data-status="<%= app.status %>">
                                        <td style="padding: 14px 18px; vertical-align: middle;">
                                            <strong style="color: #0a1628; font-size: 0.9rem;"><%= app.appointmentId %></strong>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.poNumber %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.invoiceNumber %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.city || '-' %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.docketNumber || '-' %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.forwarderName || '-' %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; color: #1a2a4a; font-weight: 600; font-size: 0.9rem;">
                                            <%= app.forwarderLRNumber || '-' %>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; text-align: center;">
                                            <span class="badge" style="background: <%= app.status === 'pending' ? 'linear-gradient(135deg, #e65100, #bf360c)' : app.status === 'confirmed' ? 'linear-gradient(135deg, #00695c, #004d40)' : 'linear-gradient(135deg, #2e7d32, #1b5e20)' %>; color: white; padding: 6px 16px; border-radius: 50px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; white-space: nowrap;">
                                                <i class="bi bi-<%= app.status === 'pending' ? 'clock-history' : app.status === 'confirmed' ? 'check-circle' : 'check-circle-fill' %>"></i>
                                                <%= app.status %>
                                            </span>
                                        </td>
                                        <td style="padding: 14px 18px; vertical-align: middle; text-align: center;">
                                            <!-- ===== Action Buttons ===== -->
                                            <div class="d-flex flex-wrap align-items-center justify-content-center gap-1">
                                                <a href="/admin/appointment/<%= app._id %>" class="btn btn-sm" style="background: rgba(201, 168, 76, 0.1); color: #c9a84c; border: 1px solid rgba(201, 168, 76, 0.15); border-radius: 6px; padding: 6px 10px; transition: all 0.3s ease; font-weight: 600; font-size: 0.65rem;" title="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="/admin/appointment/<%= app._id %>/edit" class="btn btn-sm" style="background: rgba(52, 152, 219, 0.1); color: #2980b9; border: 1px solid rgba(52, 152, 219, 0.15); border-radius: 6px; padding: 6px 10px; transition: all 0.3s ease; font-weight: 600; font-size: 0.65rem;" title="Edit Appointment">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <a href="/admin/appointment/<%= app._id %>/edit-forwarder" class="btn btn-sm" style="background: rgba(201, 168, 76, 0.1); color: #c9a84c; border: 1px solid rgba(201, 168, 76, 0.15); border-radius: 6px; padding: 6px 10px; transition: all 0.3s ease; font-weight: 600; font-size: 0.65rem;" title="Edit Forwarder">
                                                    <i class="bi bi-truck"></i>
                                                </a>
                                                <form action="/admin/appointment/<%= app._id %>" method="POST" class="d-inline">
                                                    <input type="hidden" name="_method" value="DELETE">
                                                    <button type="submit" class="btn btn-sm" style="background: rgba(231, 76, 60, 0.1); color: #e74c3c; border: 1px solid rgba(231, 76, 60, 0.15); border-radius: 6px; padding: 6px 10px; transition: all 0.3s ease; font-weight: 600; font-size: 0.65rem;" onclick="return confirm('Are you sure you want to delete this appointment?')" title="Delete Appointment">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                            <!-- ===== ✅ Status Dropdown - FIXED (removed _method) ===== -->
                                            <div class="mt-1">
                                                <form action="/admin/appointment/<%= app._id %>/status" method="POST" class="d-inline">
                                                    <!-- ✅ REMOVED _method field - route is now POST -->
                                                    <select name="status" class="form-select form-select-sm" style="border-radius: 6px; border: 2px solid rgba(201, 168, 76, 0.15); padding: 4px 8px; font-size: 0.65rem; font-weight: 600; background: white; color: #0a1628; cursor: pointer; transition: all 0.3s ease; min-width: 90px;" onchange="this.form.submit()">
                                                        <option value="pending" <%= app.status === 'pending' ? 'selected' : '' %> style="color: #e65100;">⏳ Pending</option>
                                                        <option value="confirmed" <%= app.status === 'confirmed' ? 'selected' : '' %> style="color: #00695c;">✅ Confirmed</option>
                                                        <option value="delivered" <%= app.status === 'delivered' ? 'selected' : '' %> style="color: #2e7d32;">📦 Delivered</option>
                                                    </select>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5" style="background: #f8f4eb;">
                        <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: rgba(201, 168, 76, 0.2);"></i>
                        <h5 style="color: #0a1628; margin-top: 15px; font-size: 1.3rem;">Something went wrong!</h5>
                        <p style="color: rgba(10, 22, 40, 0.4); font-size: 1rem;">Please try again later.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- ===== FILTER + SEARCH JAVASCRIPT ===== -->
<script>
function filterClientAppTable() {
    const searchInput = document.getElementById('clientAppSearchInput');
    const statusFilter = document.getElementById('clientAppStatusFilter');
    const rows = document.querySelectorAll('#clientAppTable tbody tr');
    const searchCount = document.getElementById('clientAppSearchCount');
    
    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
    const statusValue = statusFilter ? statusFilter.value : 'all';
    
    let visibleCount = 0;

    rows.forEach(row => {
        const poNumber = row.getAttribute('data-po') || '';
        const docketNumber = row.getAttribute('data-docket') || '';
        const invoiceNumber = row.getAttribute('data-invoice') || '';
        const city = row.getAttribute('data-city') || '';
        const appointmentId = row.getAttribute('data-id') || '';
        const status = row.getAttribute('data-status') || '';
        
        const matchesSearch = poNumber.includes(searchTerm) || 
                              docketNumber.includes(searchTerm) || 
                              invoiceNumber.includes(searchTerm) || 
                              city.includes(searchTerm) || 
                              appointmentId.includes(searchTerm);
        
        const matchesStatus = statusValue === 'all' || status === statusValue;
        
        if (matchesSearch && matchesStatus) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });

    searchCount.textContent = visibleCount;
}

// Event listeners
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('clientAppSearchInput');
    const statusFilter = document.getElementById('clientAppStatusFilter');
    
    if (searchInput) {
        searchInput.addEventListener('keyup', filterClientAppTable);
    }
    
    if (statusFilter) {
        statusFilter.addEventListener('change', filterClientAppTable);
    }
});
</script>

