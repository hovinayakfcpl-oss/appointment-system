<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card auth-card shadow-lg">
            <!-- Card Header -->
            <div class="card-header text-center" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border: none; padding: 30px 20px;">
                <img src="/images/faith-cargo-logo.png" alt="Faith Cargo" height="55" style="object-fit: contain; margin-bottom: 10px; filter: drop-shadow(0 0 30px rgba(201, 168, 76, 0.15));">
                <h4 style="color: #c9a84c; font-weight: 800; letter-spacing: 1px; margin: 0;">
                    <i class="bi bi-box-arrow-in-right" style="color: #e8d5a3;"></i> Welcome Back
                </h4>
                <p style="color: rgba(232, 213, 163, 0.4); font-size: 0.7rem; letter-spacing: 2.5px; margin: 5px 0 0; text-transform: uppercase;">
                    <i class="bi bi-award-fill" style="color: #c9a84c; font-size: 0.5rem;"></i> Legacy of Trust Delivery
                </p>
            </div>
            
            <!-- Card Body -->
            <div class="card-body p-4" style="background: white;">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" style="border-left: 4px solid #c62828; border-radius: 12px;">
                        <i class="bi bi-exclamation-triangle-fill" style="color: #c62828;"></i> 
                        <strong><%= error %></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <form action="/login" method="POST">
                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-envelope" style="color: #c9a84c;"></i> Email Address
                        </label>
                        <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 10px rgba(10, 22, 40, 0.05);">
                            <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 18px;">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input type="email" name="email" class="form-control" placeholder="Enter your email" required style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 18px; border-radius: 0 12px 12px 0; transition: all 0.3s ease;">
                        </div>
                    </div>
                    
                    <!-- Password -->
                    <div class="mb-3">
                        <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-lock" style="color: #c9a84c;"></i> Password
                        </label>
                        <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 10px rgba(10, 22, 40, 0.05);">
                            <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 18px;">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input type="password" name="password" class="form-control" placeholder="Enter your password" required style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 18px; border-radius: 0 12px 12px 0; transition: all 0.3s ease;">
                        </div>
                    </div>
                    
                    <!-- Forgot Password Link -->
                    <div class="text-end mb-3">
                        <a href="#" style="color: rgba(10, 22, 40, 0.4); font-size: 0.75rem; text-decoration: none; transition: all 0.3s ease; font-weight: 500;">
                            Forgot Password?
                        </a>
                    </div>
                    
                    <!-- Login Button -->
                    <button type="submit" class="btn w-100 py-2" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease;">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </button>
                </form>
                
                <!-- Signup Link -->
                <p class="text-center mt-3" style="color: rgba(10, 22, 40, 0.5); font-size: 0.85rem;">
                    Don't have account? 
                    <a href="/signup" style="color: #c9a84c; font-weight: 700; text-decoration: none; transition: all 0.3s ease; border-bottom: 2px solid transparent;">
                        Sign Up
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- ===== Extra Styles for Login Page ===== -->
<style>
    /* Form Input Focus Effect */
    .auth-card .form-control:focus {
        border-color: #c9a84c !important;
        box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.12) !important;
        transform: translateY(-2px);
    }
    
    /* Login Button Hover */
    .auth-card .btn:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 40px rgba(201, 168, 76, 0.45) !important;
        background: linear-gradient(135deg, #e8d5a3, #c9a84c) !important;
    }
    
    /* Signup Link Hover */
    .auth-card a[href="/signup"]:hover {
        color: #a8873a !important;
        border-bottom-color: #c9a84c !important;
    }
    
    /* Forgot Password Hover */
    .auth-card .text-end a:hover {
        color: #c9a84c !important;
    }
    
    /* Card Animation */
    .auth-card {
        animation: fadeInUp 0.6s ease forwards;
        border-radius: 20px !important;
        overflow: hidden !important;
        border: 1px solid rgba(201, 168, 76, 0.1) !important;
        box-shadow: 0 20px 60px rgba(10, 22, 40, 0.1) !important;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    
    /* Responsive */
    @media (max-width: 576px) {
        .auth-card .card-header {
            padding: 20px 15px !important;
        }
        
        .auth-card .card-header img {
            height: 40px !important;
        }
        
        .auth-card .card-header h4 {
            font-size: 1.1rem !important;
        }
        
        .auth-card .card-body {
            padding: 20px !important;
        }
        
        .auth-card .form-control {
            font-size: 0.85rem !important;
        }
        
        .auth-card .btn {
            font-size: 0.7rem !important;
        }
    }
</style>