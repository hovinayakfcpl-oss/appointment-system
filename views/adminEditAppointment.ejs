<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow" style="border-radius: 16px; border: 1px solid rgba(201, 168, 76, 0.08); overflow: hidden;">
            <!-- Card Header -->
            <div class="card-header" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border: none; padding: 20px 25px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0" style="color: #e8d5a3; font-weight: 700;">
                            <i class="bi bi-pencil-square" style="color: #c9a84c;"></i> Edit Forwarder Details
                        </h5>
                        <p style="color: rgba(232, 213, 163, 0.3); font-size: 0.7rem; margin: 5px 0 0; letter-spacing: 0.5px;">
                            <i class="bi bi-shield-lock-fill" style="color: #c9a84c; font-size: 0.5rem;"></i> 
                            Admin Only - Update forwarder information for this appointment
                        </p>
                    </div>
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.6rem; padding: 5px 15px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                        <i class="bi bi-person"></i> Admin
                    </span>
                </div>
            </div>
            
            <!-- Card Body -->
            <div class="card-body p-4" style="background: white;">
                <!-- Alert Messages -->
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success alert-dismissible fade show" style="border-left: 4px solid #2e7d32; border-radius: 12px;">
                        <i class="bi bi-check-circle-fill" style="color: #2e7d32;"></i> 
                        <strong><%= success %></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" style="border-left: 4px solid #c62828; border-radius: 12px;">
                        <i class="bi bi-exclamation-triangle-fill" style="color: #c62828;"></i> 
                        <strong><%= error %></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <!-- Appointment Info Card -->
                <div class="card mb-4" style="background: #f8f4eb; border-radius: 12px; border: 1px solid rgba(201, 168, 76, 0.1);">
                    <div class="card-body p-3">
                        <div class="row g-2">
                            <div class="col-md-3 col-6">
                                <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Appointment ID</small>
                                <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' ? appointment.appointmentId : '-' %></p>
                            </div>
                            <div class="col-md-3 col-6">
                                <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Client</small>
                                <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' && appointment.clientId ? appointment.clientId.name : '-' %></p>
                            </div>
                            <div class="col-md-3 col-6">
                                <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">PO Number</small>
                                <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' ? appointment.poNumber : '-' %></p>
                            </div>
                            <div class="col-md-3 col-6">
                                <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Status</small>
                                <p style="margin: 0; font-size: 0.85rem;">
                                    <span class="badge" style="background: <%= typeof appointment !== 'undefined' && appointment.status === 'pending' ? 'linear-gradient(135deg, #e65100, #bf360c)' : typeof appointment !== 'undefined' && appointment.status === 'confirmed' ? 'linear-gradient(135deg, #00695c, #004d40)' : 'linear-gradient(135deg, #2e7d32, #1b5e20)' %>; color: white; padding: 4px 14px; border-radius: 50px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                                        <%= typeof appointment !== 'undefined' ? appointment.status : '-' %>
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Edit Form -->
                <form action="/admin/appointment/<%= typeof appointment !== 'undefined' ? appointment._id : '' %>/forwarder?_method=PUT" method="POST">
                    <div class="row g-3">
                        <!-- Forwarder Name -->
                        <div class="col-12">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-truck" style="color: #c9a84c;"></i> Forwarder Name
                            </label>
                            <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 10px rgba(10, 22, 40, 0.05);">
                                <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 18px;">
                                    <i class="bi bi-truck"></i>
                                </span>
                                <input type="text" name="forwarderName" class="form-control" 
                                       value="<%= typeof appointment !== 'undefined' && appointment ? appointment.forwarderName : '' %>" 
                                       placeholder="Enter Forwarder Company Name"
                                       style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 18px; border-radius: 0 12px 12px 0; transition: all 0.3s ease;">
                            </div>
                            <small style="color: rgba(10, 22, 40, 0.3); font-size: 0.65rem; display: block; margin-top: 5px;">
                                <i class="bi bi-info-circle"></i> Name of the logistics/forwarder company handling this shipment
                            </small>
                        </div>
                        
                        <!-- Forwarder LR Number -->
                        <div class="col-12">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-upc-scan" style="color: #c9a84c;"></i> Forwarder LR Number
                            </label>
                            <div class="input-group" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 10px rgba(10, 22, 40, 0.05);">
                                <span class="input-group-text" style="background: #0a1628; color: #c9a84c; border: none; padding: 12px 18px;">
                                    <i class="bi bi-upc-scan"></i>
                                </span>
                                <input type="text" name="forwarderLRNumber" class="form-control" 
                                       value="<%= typeof appointment !== 'undefined' && appointment ? appointment.forwarderLRNumber : '' %>" 
                                       placeholder="Enter Forwarder LR Number"
                                       style="border: 2px solid #e8d5a3; border-left: none; padding: 12px 18px; border-radius: 0 12px 12px 0; transition: all 0.3s ease;">
                            </div>
                            <small style="color: rgba(10, 22, 40, 0.3); font-size: 0.65rem; display: block; margin-top: 5px;">
                                <i class="bi bi-info-circle"></i> LR (Lorry Receipt) number from the forwarder
                            </small>
                        </div>
                        
                        <!-- Current Values Display -->
                        <div class="col-12">
                            <hr style="border-color: rgba(201, 168, 76, 0.1);">
                            <div class="row g-2" style="background: #f8f4eb; border-radius: 10px; padding: 12px 15px;">
                                <div class="col-md-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Current Forwarder Name</small>
                                    <p style="color: #0a1628; font-weight: 600; margin: 0; font-size: 0.85rem;">
                                        <%= typeof appointment !== 'undefined' && appointment.forwarderName ? appointment.forwarderName : 'Not Set' %>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Current LR Number</small>
                                    <p style="color: #0a1628; font-weight: 600; margin: 0; font-size: 0.85rem;">
                                        <%= typeof appointment !== 'undefined' && appointment.forwarderLRNumber ? appointment.forwarderLRNumber : 'Not Set' %>
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Buttons -->
                        <div class="col-12 mt-3">
                            <button type="submit" class="btn" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; padding: 12px 35px; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem;">
                                <i class="bi bi-save"></i> Update Forwarder Details
                            </button>
                            <a href="/admin/client/<%= typeof appointment !== 'undefined' && appointment.clientId ? appointment.clientId._id : '' %>/appointments" class="btn" style="background: rgba(10, 22, 40, 0.05); color: #0a1628; font-weight: 600; border: 2px solid rgba(10, 22, 40, 0.1); border-radius: 50px; padding: 12px 35px; transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem; margin-left: 10px;">
                                <i class="bi bi-arrow-left"></i> Back to Appointments
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ===== Extra Styles ===== -->
<style>
    /* Form Input Focus Effect */
    .card-body .form-control:focus {
        border-color: #c9a84c !important;
        box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.1) !important;
        transform: translateY(-2px);
    }
    
    /* Submit Button Hover */
    .card-body .btn[type="submit"]:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 40px rgba(201, 168, 76, 0.45) !important;
        background: linear-gradient(135deg, #e8d5a3, #c9a84c) !important;
    }
    
    /* Back Button Hover */
    .card-body .btn[href*="/admin/client/"]:hover {
        background: rgba(10, 22, 40, 0.1) !important;
        border-color: rgba(10, 22, 40, 0.2) !important;
        transform: translateY(-2px);
    }
    
    /* Card Animation */
    .card {
        animation: fadeInUp 0.5s ease forwards;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .card-body {
            padding: 20px !important;
        }
        
        .card-body .btn {
            width: 100% !important;
            margin-left: 0 !important;
            margin-top: 10px !important;
            text-align: center !important;
            justify-content: center !important;
        }
        
        .card-body .btn[href*="/admin/client/"] {
            margin-left: 0 !important;
        }
        
        .card-header h5 {
            font-size: 1rem !important;
        }
        
        .card-header .d-flex {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 10px;
        }
    }
    
    @media (max-width: 576px) {
        .card-body {
            padding: 15px !important;
        }
        
        .card-body .input-group-text {
            padding: 10px 12px !important;
            font-size: 0.8rem !important;
        }
        
        .card-body .form-control {
            padding: 10px 12px !important;
            font-size: 0.85rem !important;
        }
        
        .card-body .btn {
            font-size: 0.65rem !important;
            padding: 10px 20px !important;
        }
        
        .card-body .row.g-2 {
            gap: 10px !important;
        }
    }
</style>