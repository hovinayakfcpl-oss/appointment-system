<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow" style="border-radius: 16px; border: 1px solid rgba(201, 168, 76, 0.08); overflow: hidden;">
            <!-- Card Header -->
            <div class="card-header" style="background: linear-gradient(135deg, #0a1628, #1a2a4a); border: none; padding: 20px 25px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0" style="color: #e8d5a3; font-weight: 700;">
                            <i class="bi bi-pencil-square" style="color: #c9a84c;"></i> Edit Appointment - Admin
                        </h5>
                        <p style="color: rgba(232, 213, 163, 0.3); font-size: 0.7rem; margin: 5px 0 0; letter-spacing: 0.5px;">
                            <i class="bi bi-shield-lock-fill" style="color: #c9a84c; font-size: 0.5rem;"></i> 
                            Admin Only - Update appointment details, forwarder info & documents
                        </p>
                    </div>
                    <span class="badge" style="background: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.6rem; padding: 5px 15px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                        <i class="bi bi-person"></i> Admin
                    </span>
                </div>
            </div>
            
            <!-- Card Body -->
            <div class="card-body p-4" style="background: white;">
                <!-- Alert Messages -->
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success alert-dismissible fade show" style="border-left: 4px solid #2e7d32; border-radius: 12px;">
                        <i class="bi bi-check-circle-fill" style="color: #2e7d32;"></i> 
                        <strong><%= success %></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" style="border-left: 4px solid #c62828; border-radius: 12px;">
                        <i class="bi bi-exclamation-triangle-fill" style="color: #c62828;"></i> 
                        <strong><%= error %></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <!-- ===== FORM - MONGODB GRIDFS ===== -->
                <form action="/admin/appointment/<%= typeof appointment !== 'undefined' ? appointment._id : '' %>/admin-update" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_method" value="PUT">
                    
                    <!-- ===== Appointment Info Card ===== -->
                    <div class="card mb-4" style="background: #f8f4eb; border-radius: 12px; border: 1px solid rgba(201, 168, 76, 0.1);">
                        <div class="card-body p-3">
                            <div class="row g-2">
                                <div class="col-md-3 col-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Appointment ID</small>
                                    <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' ? appointment.appointmentId : '-' %></p>
                                </div>
                                <div class="col-md-3 col-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Client</small>
                                    <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' && appointment.clientId ? appointment.clientId.name : '-' %></p>
                                </div>
                                <div class="col-md-3 col-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">PO Number</small>
                                    <p style="color: #0a1628; font-weight: 700; margin: 0; font-size: 0.85rem;"><%= typeof appointment !== 'undefined' ? appointment.poNumber : '-' %></p>
                                </div>
                                <div class="col-md-3 col-6">
                                    <small style="color: rgba(10, 22, 40, 0.4); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Status</small>
                                    <p style="margin: 0; font-size: 0.85rem;">
                                        <span class="badge" style="background: <%= typeof appointment !== 'undefined' && appointment.status === 'pending' ? 'linear-gradient(135deg, #e65100, #bf360c)' : typeof appointment !== 'undefined' && appointment.status === 'confirmed' ? 'linear-gradient(135deg, #00695c, #004d40)' : 'linear-gradient(135deg, #2e7d32, #1b5e20)' %>; color: white; padding: 4px 14px; border-radius: 50px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
                                            <%= typeof appointment !== 'undefined' ? appointment.status : '-' %>
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- ===== BASIC DETAILS ===== -->
                    <div class="row g-3">
                        <!-- PO Number -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-file-text" style="color: #c9a84c;"></i> PO Number <span style="color: #c62828;">*</span>
                            </label>
                            <input type="text" name="poNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.poNumber : '' %>" 
                                   placeholder="Enter PO Number" required
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Invoice Number -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-receipt" style="color: #c9a84c;"></i> Invoice Number <span style="color: #c62828;">*</span>
                            </label>
                            <input type="text" name="invoiceNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.invoiceNumber : '' %>" 
                                   placeholder="Enter Invoice Number" required
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- E-Way Bill -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-truck" style="color: #c9a84c;"></i> E-Way Bill
                            </label>
                            <input type="text" name="ewayBill" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.ewayBill : '' %>" 
                                   placeholder="Enter E-Way Bill Number"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Docket Number -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-box-seam" style="color: #c9a84c;"></i> Docket Number
                            </label>
                            <input type="text" name="docketNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.docketNumber : '' %>" 
                                   placeholder="Enter Docket Number"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- ASN Number -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-upc-scan" style="color: #c9a84c;"></i> ASN Number
                            </label>
                            <input type="text" name="asnNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.asnNumber : '' %>" 
                                   placeholder="Enter ASN Number"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Contact Person -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-person" style="color: #c9a84c;"></i> Contact Person
                            </label>
                            <input type="text" name="contactPerson" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.contactPerson : '' %>" 
                                   placeholder="Enter Contact Person Name"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Contact Number -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-telephone" style="color: #c9a84c;"></i> Contact Number
                            </label>
                            <input type="tel" name="contactNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.contactNumber : '' %>" 
                                   placeholder="Enter Contact Number"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Delivery Date -->
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-calendar3" style="color: #c9a84c;"></i> Delivery Date <span style="color: #c62828;">*</span>
                            </label>
                            <input type="date" name="deliveryDate" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? new Date(appointment.deliveryDate).toISOString().split('T')[0] : '' %>" 
                                   required
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        
                        <!-- Delivery Address -->
                        <div class="col-12">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-geo-alt" style="color: #c9a84c;"></i> Delivery Address <span style="color: #c62828;">*</span>
                            </label>
                            <textarea name="deliveryAddress" class="form-control" rows="3" required
                                      placeholder="Enter complete delivery address"
                                      style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease; resize: vertical;"><%= typeof appointment !== 'undefined' && appointment ? appointment.deliveryAddress : '' %></textarea>
                        </div>
                        
                        <!-- Remarks -->
                        <div class="col-12">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-chat" style="color: #c9a84c;"></i> Remarks
                            </label>
                            <textarea name="remarks" class="form-control" rows="2"
                                      placeholder="Any additional remarks"
                                      style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease; resize: vertical;"><%= typeof appointment !== 'undefined' && appointment ? appointment.remarks : '' %></textarea>
                        </div>
                    </div>
                    
                    <!-- ===== FORWARDER DETAILS ===== -->
                    <div class="col-12 mt-4">
                        <hr style="border-color: rgba(201, 168, 76, 0.15);">
                        <h6 style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-truck" style="color: #c9a84c;"></i> Forwarder Details
                        </h6>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-building" style="color: #c9a84c;"></i> Forwarder Name
                            </label>
                            <input type="text" name="forwarderName" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.forwarderName : '' %>" 
                                   placeholder="Enter Forwarder Name"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-upc-scan" style="color: #c9a84c;"></i> Forwarder LR Number
                            </label>
                            <input type="text" name="forwarderLRNumber" class="form-control" 
                                   value="<%= typeof appointment !== 'undefined' && appointment ? appointment.forwarderLRNumber : '' %>" 
                                   placeholder="Enter LR Number"
                                   style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 12px 18px; transition: all 0.3s ease;">
                        </div>
                    </div>
                    
                    <!-- ===== PDF DOCUMENTS SECTION - MONGODB GRIDFS ===== -->
                    <div class="col-12 mt-4">
                        <hr style="border-color: rgba(201, 168, 76, 0.15);">
                        <h6 style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-file-pdf" style="color: #c9a84c;"></i> Attach Documents (PDF Only)
                            <span style="color: rgba(10, 22, 40, 0.3); font-weight: 400; font-size: 0.6rem; text-transform: none;">
                                - Leave blank to keep existing
                            </span>
                        </h6>
                    </div>
                    
                    <div class="row g-3">
                        <!-- PO PDF -->
                        <div class="col-md-4">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-file-text" style="color: #c9a84c;"></i> PO PDF
                            </label>
                            <div>
                                <input type="file" name="poFile" class="form-control" accept=".pdf" style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 8px 12px;">
                                <% if (typeof appointment !== 'undefined' && appointment && appointment.poFileId) { %>
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        <small style="color: rgba(10, 22, 40, 0.6); font-size: 0.6rem;">
                                            <i class="bi bi-check-circle" style="color: #2e7d32;"></i> 
                                            <%= appointment.poFileOriginalName || 'Uploaded' %>
                                        </small>
                                        <button type="button" class="btn btn-sm btn-danger delete-file" 
                                                data-url="/admin/appointment/<%= appointment._id %>/file/po" 
                                                style="border-radius: 50px; padding: 2px 10px; font-size: 0.6rem;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <a href="/file/<%= appointment.poFileId %>" 
                                           target="_blank" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/file/<%= appointment.poFileId %>/download" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #2e7d32, #1b5e20); color: white; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Invoice PDF -->
                        <div class="col-md-4">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-receipt" style="color: #c9a84c;"></i> Invoice PDF
                            </label>
                            <div>
                                <input type="file" name="invoiceFile" class="form-control" accept=".pdf" style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 8px 12px;">
                                <% if (typeof appointment !== 'undefined' && appointment && appointment.invoiceFileId) { %>
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        <small style="color: rgba(10, 22, 40, 0.6); font-size: 0.6rem;">
                                            <i class="bi bi-check-circle" style="color: #2e7d32;"></i> 
                                            <%= appointment.invoiceFileOriginalName || 'Uploaded' %>
                                        </small>
                                        <button type="button" class="btn btn-sm btn-danger delete-file" 
                                                data-url="/admin/appointment/<%= appointment._id %>/file/invoice" 
                                                style="border-radius: 50px; padding: 2px 10px; font-size: 0.6rem;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <a href="/file/<%= appointment.invoiceFileId %>" 
                                           target="_blank" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/file/<%= appointment.invoiceFileId %>/download" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #2e7d32, #1b5e20); color: white; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- E-Way Bill PDF -->
                        <div class="col-md-4">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-truck" style="color: #c9a84c;"></i> E-Way Bill PDF
                            </label>
                            <div>
                                <input type="file" name="ewayBillFile" class="form-control" accept=".pdf" style="border: 2px solid #e8d5a3; border-radius: 12px; padding: 8px 12px;">
                                <% if (typeof appointment !== 'undefined' && appointment && appointment.ewayBillFileId) { %>
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        <small style="color: rgba(10, 22, 40, 0.6); font-size: 0.6rem;">
                                            <i class="bi bi-check-circle" style="color: #2e7d32;"></i> 
                                            <%= appointment.ewayBillFileOriginalName || 'Uploaded' %>
                                        </small>
                                        <button type="button" class="btn btn-sm btn-danger delete-file" 
                                                data-url="/admin/appointment/<%= appointment._id %>/file/ewaybill" 
                                                style="border-radius: 50px; padding: 2px 10px; font-size: 0.6rem;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <a href="/file/<%= appointment.ewayBillFileId %>" 
                                           target="_blank" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/file/<%= appointment.ewayBillFileId %>/download" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #2e7d32, #1b5e20); color: white; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <small style="color: rgba(10, 22, 40, 0.3); font-size: 0.6rem;">
                            <i class="bi bi-info-circle"></i> Only PDF files are allowed. Max size: 5MB per file.
                            <span style="display: block; margin-top: 2px;">
                                <i class="bi bi-eye" style="color: #c9a84c;"></i> View | 
                                <i class="bi bi-download" style="color: #2e7d32;"></i> Download
                            </span>
                        </small>
                    </div>
                    
                    <!-- ===== POD UPLOAD SECTION - ADMIN ONLY ===== -->
                    <div class="col-12 mt-3">
                        <hr style="border-color: rgba(201, 168, 76, 0.15);">
                        <h6 style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-file-earmark-pdf" style="color: #c9a84c;"></i> POD Upload - <span style="color: #c62828;">Admin Only</span>
                        </h6>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" style="color: #0a1628; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="bi bi-file-check" style="color: #c9a84c;"></i> POD PDF
                            </label>
                            <div>
                                <input type="file" name="podFile" class="form-control" accept=".pdf" style="border: 2px solid #c9a84c; border-radius: 12px; padding: 8px 12px;">
                                <% if (typeof appointment !== 'undefined' && appointment && appointment.podFileId) { %>
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        <small style="color: rgba(10, 22, 40, 0.6); font-size: 0.6rem;">
                                            <i class="bi bi-check-circle" style="color: #2e7d32;"></i> 
                                            <%= appointment.podFileOriginalName || 'Uploaded' %>
                                        </small>
                                        <button type="button" class="btn btn-sm btn-danger delete-file" 
                                                data-url="/admin/appointment/<%= appointment._id %>/file/pod" 
                                                style="border-radius: 50px; padding: 2px 10px; font-size: 0.6rem;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <a href="/file/<%= appointment.podFileId %>" 
                                           target="_blank" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/file/<%= appointment.podFileId %>/download" 
                                           class="btn btn-sm" 
                                           style="background: linear-gradient(135deg, #2e7d32, #1b5e20); color: white; border: none; border-radius: 50px; padding: 2px 10px; font-size: 0.6rem; text-decoration: none;">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <small style="color: rgba(10, 22, 40, 0.3); font-size: 0.6rem;">
                            <i class="bi bi-info-circle"></i> Only PDF files are allowed. Max size: 5MB.
                        </small>
                    </div>
                    
                    <!-- ===== BUTTONS ===== -->
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn" style="background: linear-gradient(135deg, #c9a84c, #a8873a); color: #0a1628; font-weight: 700; border: none; border-radius: 50px; padding: 12px 35px; box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3); transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem;">
                            <i class="bi bi-save"></i> Update Appointment
                        </button>
